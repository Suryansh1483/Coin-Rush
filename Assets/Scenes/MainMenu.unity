  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "WELCOME TO COIN RUSH!\r\n\r\nYour objective is simple:\r\n           \u2022
    Collect all 25 coins as quickly as possible.\r\n           \u2022 Avoid the fire
    hazards scattered across the map.\r\n           \u2022 Each fire hit reduces
    your Health by 20 and adds 2 seconds to your time.\r\n           \u2022 You start
    with 100 Health. If your Health reaches 0, the run ends.\r\n           \u2022
    Complete the challenge in the shortest time to achieve the highest score.\r\n\r\nCONTROLS\r\n         
    \u2022 W, A, S, D \u2014 Move\r\n          \u2022 Mouse \u2014 Rotate Camera\r\n         
    \u2022 ESC \u2014 Pause / Resume Game\r\n\r\nGood luck, collect every coin, and
    beat the clock!\r\n"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 125cb55b44b24c4393181402bc6200e6, type: 2}
